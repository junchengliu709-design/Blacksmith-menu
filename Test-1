<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>ILI9341 Mock - Blacksmith</title>
  <style>
#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_ILI9341.h>

// --------- TFT wiring (change to match your STM32 wiring) ---------
#define TFT_CS   PB12
#define TFT_DC   PB1
#define TFT_RST  PB0   // use -1 if tied to reset

Adafruit_ILI9341 tft(TFT_CS, TFT_DC, TFT_RST);

// --------- Buttons (active LOW, change pins if needed) ---------
#define BTN_UP_PIN     PA0
#define BTN_DOWN_PIN   PA1
#define BTN_A_PIN      PA2
#define BTN_B_PIN      PA3

// --------- Simple UI colors ---------
static const uint16_t C_BG     = ILI9341_BLACK;
static const uint16_t C_BAR    = ILI9341_NAVY;
static const uint16_t C_TEXT   = ILI9341_WHITE;
static const uint16_t C_MUTED  = ILI9341_LIGHTGREY;
static const uint16_t C_CARD   = ILI9341_DARKGREY;
static const uint16_t C_ACCENT = ILI9341_CYAN;
static const uint16_t C_SEL_BG = ILI9341_BLUE;

enum AppState { ST_MENU, ST_GAME };
static AppState state = ST_MENU;

static uint32_t heat = 45;     // 0..100
static uint32_t progress = 10; // 0..100

static bool prevA = false;
static bool prevB = false;

static bool readBtn(uint8_t pin) {
  return digitalRead(pin) == LOW;
}

static void drawTopBar(const char* title) {
  tft.fillRect(0, 0, tft.width(), 34, C_BAR);
  tft.drawFastHLine(0, 34, tft.width(), ILI9341_BLACK);

  tft.setTextColor(C_TEXT);
  tft.setTextSize(2);
  tft.setCursor(10, 8);
  tft.print(title);
}

static void drawFooter(const char* hint) {
  int y = tft.height() - 24;
  tft.drawFastHLine(0, y, tft.width(), ILI9341_DARKGREY);

  tft.setTextSize(1);
  tft.setTextColor(C_MUTED);
  tft.setCursor(10, y + 8);
  tft.print(hint);
}

static void drawAnvilIcon(int x, int y, uint16_t col) {
  // very simple anvil silhouette
  tft.fillRect(x + 6,  y + 22, 42, 10, col);     // base
  tft.fillRect(x + 14, y + 12, 26, 12, col);     // body
  tft.fillRect(x + 2,  y + 14, 18, 8, col);      // horn
  tft.fillRect(x + 20, y + 2,  18, 10, col);     // top
  tft.drawRect(x + 1, y + 1, 50, 34, ILI9341_BLACK);
}

static void drawMenuScreen() {
  tft.fillScreen(C_BG);
  drawTopBar("MINI GAME");

  int margin = 16;
  int cw = tft.width() - margin * 2;
  int ch = 110;
  int cy = 58;

  // single card (always selected)
  tft.fillRoundRect(margin, cy, cw, ch, 14, C_SEL_BG);
  tft.drawRoundRect(margin, cy, cw, ch, 14, C_ACCENT);
  tft.fillRoundRect(margin + 12, cy + 14, 6, ch - 28, 3, C_ACCENT);

  tft.setTextColor(C_TEXT);
  tft.setTextSize(3);
  tft.setCursor(margin + 30, cy + 18);
  tft.print("BLACKSMITH");

  tft.setTextSize(1);
  tft.setTextColor(C_TEXT);
  tft.setCursor(margin + 32, cy + 60);
  tft.print("Forge blades, manage heat,");

  tft.setCursor(margin + 32, cy + 74);
  tft.print("strike at the right timing.");

  drawAnvilIcon(margin + cw - 70, cy + 26, C_ACCENT);

  drawFooter("A: Start   B: (unused)   UP/DOWN: (unused)");
}

static void drawBar(int x, int y, int w, int h, uint32_t val, uint16_t fillCol) {
  if (val > 100) val = 100;
  tft.drawRect(x, y, w, h, ILI9341_WHITE);
  int fw = (int)((w - 2) * (val / 100.0f));
  tft.fillRect(x + 1, y + 1, w - 2, h - 2, ILI9341_BLACK);
  tft.fillRect(x + 1, y + 1, fw, h - 2, fillCol);
}

static void drawGameScreen() {
  tft.fillScreen(C_BG);
  drawTopBar("BLACKSMITH");

  // Anvil area
  tft.fillRoundRect(30, 70, 260, 110, 18, ILI9341_DARKGREY);
  tft.drawRoundRect(30, 70, 260, 110, 18, ILI9341_BLACK);

  // blade on anvil
  tft.fillRect(90, 118, 140, 10, ILI9341_SILVER);
  tft.fillTriangle(230, 118, 250, 123, 230, 128, ILI9341_SILVER);

  // hammer icon
  tft.fillRect(55, 92, 12, 40, ILI9341_BROWN);
  tft.fillRect(45, 82, 32, 14, ILI9341_LIGHTGREY);

  // HUD
  tft.setTextSize(1);
  tft.setTextColor(C_TEXT);
  tft.setCursor(20, 44);
  tft.print("HEAT");
  drawBar(60, 42, 100, 12, heat, ILI9341_RED);

  tft.setCursor(180, 44);
  tft.print("PROG");
  drawBar(220, 42, 80, 12, progress, ILI9341_GREEN);

  drawFooter("A: Strike   B: Back");
}

static void enterMenu() {
  state = ST_MENU;
  drawMenuScreen();
}

static void enterGame() {
  state = ST_GAME;
  heat = 45;
  progress = 10;
  drawGameScreen();
}

void setup() {
  pinMode(BTN_UP_PIN, INPUT_PULLUP);
  pinMode(BTN_DOWN_PIN, INPUT_PULLUP);
  pinMode(BTN_A_PIN, INPUT_PULLUP);
  pinMode(BTN_B_PIN, INPUT_PULLUP);

  tft.begin();
  tft.setRotation(1); // landscape 320x240
  enterMenu();
}

void loop() {
  bool a = readBtn(BTN_A_PIN);
  bool b = readBtn(BTN_B_PIN);

  bool aPressed = (a && !prevA);
  bool bPressed = (b && !prevB);

  prevA = a;
  prevB = b;

  if (state == ST_MENU) {
    if (aPressed) enterGame();
  } else {
    if (bPressed) enterMenu();

    if (aPressed) {
      // strike: heat goes up, progress goes up; redraw HUD quickly
      heat = (heat + 12) > 100 ? 100 : (heat + 12);
      progress = (progress + 8) > 100 ? 100 : (progress + 8);

      // simple cooling over time
      // (keep it cheap: just refresh bars here)
      tft.setTextColor(C_TEXT);
      drawBar(60, 42, 100, 12, heat, ILI9341_RED);
      drawBar(220, 42, 80, 12, progress, ILI9341_GREEN);

      if (progress >= 100) {
        tft.setTextSize(2);
        tft.setTextColor(ILI9341_YELLOW);
        tft.setCursor(70, 200);
        tft.print("FORGED!");
      }
    }

    // idle cooling
    static uint32_t lastCool = 0;
    uint32_t now = millis();
    if (now - lastCool > 250) {
      lastCool = now;
      if (heat > 0) heat--;
      drawBar(60, 42, 100, 12, heat, ILI9341_RED);
    }
  }

  delay(10);
}
})();
</script>
</body>
</html>
