<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>ILI9341 Mock - Blacksmith</title>
  <style>
    body{
      margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;
      background:#0b0f16; color:#eaeaea; display:flex; min-height:100vh;
      align-items:center; justify-content:center;
    }
    .wrap{ display:flex; gap:18px; align-items:center; padding:18px; flex-wrap:wrap; justify-content:center;}
    .panel{
      background:#111827; border:1px solid #243244; border-radius:14px;
      padding:14px; box-shadow: 0 10px 30px rgba(0,0,0,.35);
    }
    .title{ font-weight:700; margin:0 0 10px 0; opacity:.9; }
    .screen{
      width:min(92vw, 520px);
      aspect-ratio: 4 / 3; /* 320x240 */
      background:#000; border-radius:14px; border:1px solid #2a3a52;
      display:flex; align-items:center; justify-content:center;
      padding:10px;
    }
    canvas{
      image-rendering: pixelated;
      width:100%;
      height:100%;
      border-radius:10px;
      background:#000;
    }
    .controls{ display:flex; gap:10px; flex-wrap:wrap; }
    button{
      cursor:pointer; border:none; border-radius:12px; padding:10px 14px;
      background:#1f2937; color:#fff; font-weight:700; letter-spacing:.3px;
      border:1px solid #2b3b55;
    }
    button:active{ transform: translateY(1px); }
    .hint{ font-size:13px; opacity:.8; margin-top:10px; line-height:1.35; }
    .kbd{ padding:2px 7px; border-radius:8px; background:#0b1220; border:1px solid #243244; font-weight:700; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="panel">
      <p class="title">ILI9341 Layout Mock (320×240)</p>
      <div class="screen">
        <canvas id="tft" width="320" height="240"></canvas>
      </div>
      <div class="hint">
        Keys: <span class="kbd">A</span> Start/Strike, <span class="kbd">B</span> Back<br>
        This is a web preview of your TFT UI layout.
      </div>
    </div>

    <div class="panel" style="min-width:240px; max-width:320px;">
      <p class="title">Controls</p>
      <div class="controls">
        <button id="btnA">A</button>
        <button id="btnB">B</button>
        <button id="btnReset">Reset</button>
      </div>
      <div class="hint">
        Menu → press <span class="kbd">A</span> → Loading… → Game<br>
        Game → press <span class="kbd">B</span> → Menu<br><br>
        (Beginner-style state machine, simple drawing, fixed coordinates)
      </div>
    </div>
  </div>

<script>
(() => {
  const c = document.getElementById('tft');
  const ctx = c.getContext('2d');

  // ----- "ILI9341-like" palette (approx) -----
  const COL = {
    BLACK:  '#000000',
    WHITE:  '#ffffff',
    NAVY:   '#000050',
    BLUE:   '#0050c8',
    CYAN:   '#00c8c8',
    DGREY:  '#3c3c3c',
    LGREY:  '#aaaaaa',
    RED:    '#e02020',
    GREEN:  '#1bbf55',
    SILVER: '#cfd3d9',
    YELLOW: '#ffd400'
  };

  // ----- App state -----
  // page: 0 menu, 1 loading, 2 game
  let page = 0;
  let heat = 45;       // 0..100
  let prog = 10;       // 0..100
  let loadingUntil = 0;

  function clear() {
    ctx.fillStyle = COL.BLACK;
    ctx.fillRect(0, 0, 320, 240);
  }
  function hline(y, color) {
    ctx.fillStyle = color;
    ctx.fillRect(0, y, 320, 1);
  }
  function rect(x,y,w,h,color) {
    ctx.fillStyle = color;
    ctx.fillRect(x,y,w,h);
  }
  function outline(x,y,w,h,color) {
    ctx.strokeStyle = color;
    ctx.strokeRect(x+0.5,y+0.5,w-1,h-1);
  }

  // simple rounded rect (beginner-ish)
  function roundRect(x,y,w,h,r,fill,stroke) {
    ctx.beginPath();
    ctx.moveTo(x+r, y);
    ctx.arcTo(x+w, y, x+w, y+h, r);
    ctx.arcTo(x+w, y+h, x, y+h, r);
    ctx.arcTo(x, y+h, x, y, r);
    ctx.arcTo(x, y, x+w, y, r);
    if(fill){
      ctx.fillStyle = fill;
      ctx.fill();
    }
    if(stroke){
      ctx.strokeStyle = stroke;
      ctx.lineWidth = 2;
      ctx.stroke();
      ctx.lineWidth = 1;
    }
  }

  function text(x,y,str,size,color) {
    ctx.fillStyle = color;
    ctx.font = `${size}px system-ui, Arial`;
    ctx.fillText(str, x, y);
  }

  // ----- Screens (fixed coordinates like your TFT code) -----
  function drawMenu() {
    clear();

    // header (0,0..320,34)
    rect(0,0,320,34, COL.NAVY);
    hline(34, COL.BLACK);
    text(10, 24, "MINI GAME", 18, COL.WHITE);

    // card (16,58,288,110)
    roundRect(16,58,288,110,14, COL.BLUE, COL.CYAN)
    // left accent strip (28,72,6,82)
    roundRect(28,72,6,82,3, COL.CYAN, null);
    // title
    text(46, 98, "BLACKSMITH", 26, COL.WHITE);
    // description
    text(48, 132, "Forge blades, manage heat,", 14, COL.WHITE);
    text(48, 150, "strike at the right timing.", 14, COL.WHITE);

    // anvil icon (approx like your blocks)
    rect(240,108,42,10, COL.CYAN);   // base
    rect(248,98,26,12, COL.CYAN);    // body
    rect(236,100,18,8, COL.CYAN);    // horn
    rect(254,88,18,10, COL.CYAN);    // top

    // footer
    hline(216, COL.DGREY);
    text(10, 232, "Press A to start", 12, COL.LGREY);
  }

  function drawLoading() {
    clear();
    text(70, 125, "Loading...", 28, COL.WHITE);
  }

  function drawBar(x,y,w,h,val,fill) {
    // border
    ctx.strokeStyle = COL.WHITE;
    ctx.strokeRect(x+0.5,y+0.5,w,h);
    // background
    rect(x+1,y+1,w-2,h-2, COL.BLACK);
    // fill
    const fw = Math.floor((w-2) * Math.max(0, Math.min(100,val)) / 100);
    rect(x+1,y+1,fw,h-2, fill);
  }

  function drawGame() {
    clear();

    // header
    rect(0,0,320,34, COL.NAVY);
    text(10, 24, "BLACKSMITH", 18, COL.WHITE);

    // HUD labels
    text(20, 55, "HEAT", 12, COL.WHITE);
    drawBar(60, 44, 100, 12, heat, COL.RED);

    text(180, 55, "PROG", 12, COL.WHITE);
    drawBar(220, 44, 80, 12, prog, COL.GREEN);

    // placeholder area (40,140,240,70)
    roundRect(40,140,240,70,14, COL.DGREY, null);

    // blade (110,168,140,8) + tip triangle
    rect(110,168,140,8, COL.SILVER);
    ctx.fillStyle = COL.SILVER;
    ctx.beginPath();
    ctx.moveTo(250,168);
    ctx.lineTo(268,172);
    ctx.lineTo(250,176);
    ctx.closePath();
    ctx.fill()
    // simple hammer block
    rect(55,92,12,40, '#8b5a2b'); // handle
    rect(45,82,32,14, COL.LGREY); // head

    // footer
    hline(216, COL.DGREY);
    text(10, 232, "Press B to go back | A = strike", 12, COL.LGREY);

    if(prog >= 100){
      text(115, 205, "FORGED!", 18, COL.YELLOW);
    }
  }

  function render() {
    if(page === 0) drawMenu();
    else if(page === 1) drawLoading();
    else drawGame();
  }

  // ----- Input -----
  function pressA(){
    if(page === 0){
      page = 1;
      loadingUntil = Date.now() + 700;
      render();
    } else if(page === 2){
      // strike
      heat = Math.min(100, heat + 12);
      prog = Math.min(100, prog + 8);
      render();
    }
  }

  function pressB(){
    if(page === 2){
      page = 0;
      render();
    }
  }

  function reset(){
    page = 0;
    heat = 45;
    prog = 10;
    loadingUntil = 0;
    render();
  }

  document.getElementById('btnA').addEventListener('click', pressA);
  document.getElementById('btnB').addEventListener('click', pressB);
  document.getElementById('btnReset').addEventListener('click', reset);

  window.addEventListener('keydown', (e) => {
    if(e.key === 'a' || e.key === 'A') pressA();
    if(e.key === 'b' || e.key === 'B') pressB();
  });

  // ----- simple update loop for loading + cooling -----
  function tick(){
    const now = Date.now();




    // loading -> game
    if(page === 1 && now >= loadingUntil){
      page = 2;
      heat = 45; prog = 10;
      render();
    }

    // idle cooling in game
    if(page === 2){
      // cool down slowly
      if(heat > 0 && (now % 250 < 16)) {
        heat = Math.max(0, heat - 1);
        render();
      }
    }

    requestAnimationFrame(tick);
  }

  render();
  requestAnimationFrame(tick);
})();
</script>
</body>
</html>
