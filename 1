<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Blacksmith Web Simulator</title>
  <style>
    body{ margin:0; font-family: Arial, "Microsoft YaHei"; background:#0b0f16; color:#eee; }
    .wrap{ display:flex; gap:16px; padding:16px; flex-wrap:wrap; justify-content:center; }
    .card{ background:#111827; border:1px solid #243244; border-radius:14px; padding:14px; }
    canvas{ width:min(92vw, 520px); height:auto; border-radius:10px; background:#000; border:1px solid #2a3a52; image-rendering: pixelated; }
    button{
      border:1px solid #2b3b55; background:#1f2937; color:#fff;
      border-radius:12px; padding:10px 14px; font-weight:700; cursor:pointer;
    }
    button:active{ transform: translateY(1px); }
    .hint{ font-size:13px; opacity:.85; line-height:1.4; margin-top:10px; }
    .kbd{ padding:2px 7px; border-radius:8px; background:#0b1220; border:1px solid #243244; font-weight:700; }
  </style>
</head>
<body>
<div class="wrap">
  <div class="card">
    <div style="font-weight:700;margin-bottom:10px;">Blacksmith (Web Simulator) — 320×240</div>
    <canvas id="cv" width="320" height="240"></canvas>
    <div class="hint">
      键盘：<span class="kbd">A</span> 或 <span class="kbd">Space</span> = 敲击 / 开始，
      <span class="kbd">B</span> = 返回菜单<br>
      手机/触屏：用右侧按钮
    </div>
  </div>

  <div class="card" style="min-width:220px;">
    <div style="font-weight:700;margin-bottom:10px;">Controls</div>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <button id="btnA">A / Strike</button>
      <button id="btnB">B / Back</button>
      <button id="btnR">Reset</button>
    </div>
    <div class="hint">
      玩法：看 Timing 的指针跑到中间亮区时按 A，越准越加进度。<br>
      Heat 太低/太高都会变差（简单惩罚）。
    </div>
  </div>
</div>

<script>
  const c = document.getElementById("cv");
  const g = c.getContext("2d");

  // 颜色（随便定的，接近 ILI9341 风格）
  const COL = {
    black:"#000", white:"#fff",
    navy:"#000050", blue:"#0050c8", cyan:"#00c8c8",
    dgrey:"#3c3c3c", lgrey:"#aaaaaa",
    red:"#e02020", green:"#1bbf55", yellow:"#ffd400",
    silver:"#cfd3d9"
  };

  // 状态：0菜单 1loading 2游戏
  let page = 0;
  let loadingEnd = 0;

  // 游戏数据
  let heat = 45;      // 0..100
  let prog = 0;       // 0..100
  let timingX = 0;    // 0..1
  let timingDir = 1;  // 1 or -1
  let forged = false;

  // --------- 画图工具（写得直白一点）---------
  function cls() {
    g.fillStyle = COL.black;
    g.fillRect(0,0,320,240);
  }
  function rect(x,y,w,h,col) {
    g.fillStyle = col;
    g.fillRect(x,y,w,h);
  }
  function lineH(y,col) {
    rect(0,y,320,1,col);
  }
  function text(x,y,str,size,col) {
    g.fillStyle = col;
    g.font = size + "px Arial";
    g.fillText(str,x,y);
  }
  function bar(x,y,w,h,val,fillCol) {
    // 边框
    g.strokeStyle = COL.white;
    g.strokeRect(x+0.5,y+0.5,w,h);
    // 底色
    rect(x+1,y+1,w-2,h-2,COL.black);
    // 填充
    if(val < 0) val = 0;
    if(val > 100) val = 100;
    const fw = Math.floor((w-2) * val / 100);
    rect(x+1,y+1,fw,h-2,fillCol);
  }

  // --------- 各页面绘制 ---------
  function drawMenu() {
    cls();
    rect(0,0,320,34,COL.navy);
    lineH(34,COL.black);
    text(10,24,"MINI GAME",18,COL.white);

    // 单卡片
    rect(16,58,288,110,COL.blue);
    g.strokeStyle = COL.cyan;
    g.lineWidth = 2;
    g.strokeRect(16.5,58.5,287,109);
    g.lineWidth = 1;

    rect(28,72,6,82,COL.cyan);

    text(46,98,"BLACKSMITH",26,COL.white);
    text(48,132,"Press A to start",14,COL.white);

    // 简单铁砧
    rect(240,108,42,10,COL.cyan);
    rect(248,98,26,12,COL.cyan);
    rect(236,100,18,8,COL.cyan);
    rect(254,88,18,10,COL.cyan);

    lineH(216,COL.dgrey);
    text(10,232,"A: Start   B: (unused)",12,COL.lgrey);
  }

  function drawLoading() {
    cls();
    text(70,125,"Loading...",28,COL.white);
  }

  function drawGame() {
    cls();

    rect(0,0,320,34,COL.navy);
    text(10,24,"BLACKSMITH",18,COL.white);

    // HUD
    text(20,55,"HEAT",12,COL.white);
    bar(60,44,100,12,heat,COL.red);

    text(180,55,"PROG",12,COL.white);
    bar(220,44,80,12,prog,COL.green);

    // timing bar
    text(20,78,"TIMING",12,COL.white);
    g.strokeStyle = COL.white;
    g.strokeRect(60.5,68.5,240,14);

    // sweet spot (中间亮区)
    rect(60 + 110, 69, 40, 12, "#203a4a");

    // pointer
    const px = 60 + Math.floor(240 * timingX);
    rect(px, 69, 3, 12, COL.yellow);

    // 铁砧区域
    rect(40,140,240,70,COL.dgrey);
    // 刀胚
    rect(110,168,140,8,COL.silver);
    g.fillStyle = COL.silver;
    g.beginPath();
    g.moveTo(250,168); g.lineTo(268,172); g.lineTo(250,176);
    g.closePath(); g.fill();

    // 锤子（块状）
    rect(55,92,12,40,"#8b5a2b");
    rect(45,82,32,14,COL.lgrey);

    lineH(216,COL.dgrey);
    text(10,232,"A: Strike   B: Back",12,COL.lgrey);

    if(forged) {
      text(110,205,"FORGED!",18,COL.yellow);
    }
  }

  // --------- 游戏逻辑 ---------
  function resetAll() {
    page = 0;
    heat = 45;
    prog = 0;
    timingX = 0;
    timingDir = 1;
    forged = false;
    drawMenu();
  }

  function pressA() {
    if(page === 0) {
      page = 1;
      loadingEnd = Date.now() + 700;
      drawLoading();
      return;
    }

    if(page === 2) {
      if(forged) return;

      // 计算敲击准不准（sweet spot：大概在 0.46~0.62）
      const inZone = (timingX > 0.46 && timingX < 0.62);
      let gain = 0;

      if(inZone) gain = 14;     // 准：加得多
      else gain = 5;            // 不准：加得少

      // heat 影响：太低/太高减半
      if(heat < 20 || heat > 90) gain = Math.floor(gain * 0.5);

      prog += gain;
      if(prog >= 100) { prog = 100; forged = true; }

      // 敲击升温
      heat += 10;
      if(heat > 100) heat = 100;

      drawGame();
    }
  }

  function pressB() {
    if(page === 2) {
      page = 0;
      drawMenu();
    }
  }

  // --------- 主循环（刷新 + 冷却 + timing移动）---------
  function tick() {
    const now = Date.now();

    if(page === 1 && now >= loadingEnd) {
      page = 2;
      heat = 45;
      prog = 10;
      timingX = 0;
      timingDir = 1;
      forged = false;
      drawGame();
    }

    if(page === 2) {
      // timing 往返移动
      timingX += 0.018 * timingDir;
      if(timingX > 1) { timingX = 1; timingDir = -1; }
      if(timingX < 0) { timingX = 0; timingDir = 1; }

      // 慢慢降温
      heat -= 0.08;
      if(heat < 0) heat = 0;

      // 简单重画（320x240 很轻）
      drawGame();
    }

    requestAnimationFrame(tick);
  }

  // 按钮
  document.getElementById("btnA").onclick = pressA;
  document.getElementById("btnB").onclick = pressB;
  document.getElementById("btnR").onclick = resetAll;

  // 键盘
  window.addEventListener("keydown", (e) => {
    if(e.key === "a" || e.key === "A" || e.code === "Space") pressA();
    if(e.key === "b" || e.key === "B") pressB();
  });

  // 启动
  drawMenu();
  requestAnimationFrame(tick);
</script>
</body>
</html>
